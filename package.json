{
  "name": "ballista",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency 1 run build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "bench:solverkit": "node scripts/check-benchmark-regression.mjs",
    "check:cross-engine-drift": "node scripts/measure-cross-engine-drift.mjs",
    "lint": "eslint .",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm typecheck && pnpm lint && pnpm lint:deps && pnpm test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "dependency-cruiser": "^16.4.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.15.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "playwright": "^1.61.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": "prettier --write"
  }
}
